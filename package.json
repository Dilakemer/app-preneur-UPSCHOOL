{
  "name": "caremind-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn backend/index.ts",
    "start": "npm run build && node dist/index.js",
    "build": "tsc",
    "test": "jest --config jest.config.json",
    "test:watch": "jest --config jest.config.json --watch",
    "test:coverage": "jest --config jest.config.json --coverage",
    "test:backend": "jest --config jest.config.json tests/backend",
    "test:frontend": "jest --config jest.config.json tests/frontend"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/uuid": "^11.0.0",
    "axios": "^1.16.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
